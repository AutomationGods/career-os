# Local host defaults. Docker Compose injects container-safe DATABASE_URL and REDIS_URL automatically.
DATABASE_URL="postgresql://career_os:career_os@localhost:55434/career_os?schema=public"
POSTGRES_HOST_PORT=55434
WEB_HOST_PORT=3000
REDIS_URL="redis://localhost:6379"
CAREER_OS_COMMAND_RUNTIME="prisma"

# WorkOS AuthKit. Placeholders wire the integration; real sign-in needs `npx workos auth login`,
# `npx workos config redirect add http://localhost:3000/auth/callback`, then real values copied into .env.
WORKOS_CLIENT_ID="client_placeholder"
WORKOS_API_KEY="sk_test_placeholder"
WORKOS_COOKIE_PASSWORD="placeholder-cookie-password-at-least-32-chars"
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3000/auth/callback"
WORKOS_BASE_URL="http://localhost:3000"

# Local development only. Keep false in production and Docker Compose.
CAREER_OS_AUTH_DISABLED="false"
CAREER_OS_ENABLE_LOCAL_DEMO_ROUTES="false"

# AI providers.
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
OPENAI_OAUTH_CLIENT_ID=""
OPENAI_OAUTH_CLIENT_SECRET=""
OPENAI_OAUTH_REDIRECT_URI="http://localhost:3000/api/ai/openai/oauth/callback"
OPENAI_OAUTH_SCOPES=""

# Hermes Agent server-to-server integration.
# Docker Compose runs Hermes as a sidecar and points Career OS web to http://hermes:8642.
HERMES_AGENT_ENABLED="true"
HERMES_AGENT_API_BASE_URL="http://127.0.0.1:8642"
HERMES_AGENT_API_KEY=""
HERMES_AGENT_MODEL="hermes-agent"
HERMES_AGENT_TIMEOUT_MS="60000"
HERMES_AGENT_HOST_PORT=8642
HERMES_UID=10000
HERMES_GID=10000
