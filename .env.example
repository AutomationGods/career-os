# Local database and cache
DATABASE_URL="postgresql://career_os:career_os@localhost:55434/career_os?schema=public"
POSTGRES_HOST_PORT=55434
REDIS_URL="redis://localhost:6379"

# Auth.js / NextAuth
# Production: generate a real value with `openssl rand -base64 32`; never use change-me.
NEXTAUTH_SECRET="local-dev-only-generate-a-real-secret-before-production"
NEXTAUTH_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"
# Local dev without Google OAuth uses this email on the built-in credentials sign-in page.
# Production single-user alpha must set this to the allowed real account email(s).
AUTH_ALLOWED_EMAILS="local-user@career-os.local"

# Google OAuth provider for production sign-in
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional AI integrations; public launch MVP does not require provider calls.
OPENAI_API_KEY=""

# Feature flags default to public-launch-safe values.
ENABLE_DEV_COMMANDS=false
ENABLE_PLACEHOLDER_DOMAINS=false
ENABLE_EXTERNAL_COLLECTORS=false
ENABLE_PRODUCTION_DEMO_DATA=false
